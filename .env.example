# ---------------------------------------------------------------------------
# Ghost Mode — Environment Variables Template
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ghost_mode?schema=public"

# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
NEXT_PUBLIC_APPWRITE_PROJECT_ID="your-project-id"
APPWRITE_API_KEY="your-api-key"

# ---------------------------------------------------------------------------
# Abacus.AI — used for roadmap generation, mission generation,
# proof validation, and the Ruthless Decision Filter.
# ---------------------------------------------------------------------------
# Your Abacus.AI API key (https://abacus.ai -> Profile -> API Keys)
ABACUS_API_KEY="your-abacus-api-key"

# Optional: model/deployment to route requests through.
# If you use the RouteLLM / ChatLLM OpenAI-compatible endpoint, set these.
ABACUS_LLM_BASE_URL="https://routellm.abacus.ai/v1"
ABACUS_LLM_MODEL="route-llm"

# If ABACUS_API_KEY is not set, the app falls back to a deterministic
# local heuristic engine so the flows remain fully functional in dev.
