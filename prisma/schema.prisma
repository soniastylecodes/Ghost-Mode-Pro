// Ghost Mode — Prisma schema
// Core data model per PRD Section 8.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / User
// ---------------------------------------------------------------------------
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?
  image           String?
  emailVerified   DateTime?
  pushoverUserKey String?
  role            String    @default("user") // "user" | "admin"
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  notificationPreferences String?
  wakeTime                String?
  sleepTime               String?
  napWindows              String?
  pushoverApiToken        String?
  baseCurrency            String    @default("NGN")

  accounts   Account[]
  sessions   Session[]
  goals      Goal[]
  streak     Streak?
  roleModels RoleModel[]
  leads      Lead[]
  revenueLogs RevenueLog[]
}

// NextAuth adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Goal
// ---------------------------------------------------------------------------
model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  deadline    DateTime
  status              String     @default("active")
  statement           String?
  targetNumber        Float?
  reason              String?
  definitionOfSuccess String?
  outcomeThreads      String? // Stored as JSON
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vow               Vow?
  interviewResponse InterviewResponse?
  roadmap           Roadmap?
  missions          Mission[]
  weeklyReviews     WeeklyReview[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Interview Response
// One-to-one snapshot of the intake interview per goal.
// ---------------------------------------------------------------------------
model InterviewResponse {
  id                 String   @id @default(cuid())
  goalId             String   @unique
  income             String   // current income situation
  skills             String   // relevant skills / assets
  hoursAvailable     Float    // hours available per day
  commitments        String   // existing commitments
  distractions       String   // known distractions
  createdAt          DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Roadmap (HIDDEN from user — internal AI plan)
// ---------------------------------------------------------------------------
model Roadmap {
  id          String   @id @default(cuid())
  goalId      String   @unique
  phases      Json // ordered phases: [{ name, objective, order, milestones[] }]
  currentPhase Int     @default(0)
  rawPlan     String?  // full AI narrative plan (internal)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Mission — a day's worth of work (max 3 primary tasks)
// ---------------------------------------------------------------------------
model Mission {
  id         String          @id @default(cuid())
  goalId     String
  date       DateTime        @default(now()) // the mission day
  phaseIndex Int             @default(0)
  status     String          @default("active")
  summary    String?
  deadline   DateTime        // today's deadline for primary missions
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  goal           Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  primaryTasks   PrimaryTask[]
  secondaryTasks SecondaryTask[]
  reflection     Reflection?

  @@index([goalId])
}

// ---------------------------------------------------------------------------
// PrimaryTask — a core task that requires proof validation
// ---------------------------------------------------------------------------
model PrimaryTask {
  id                String   @id @default(cuid())
  missionId         String
  objective         String
  priority          Int      // 1-3
  estDuration       Int      // minutes
  expectedOutcome   String
  proofTypeRequired String   @default("text")
  status                  String   @default("pending")
  commitmentWindowMinutes Int?
  extensionRequested      Boolean  @default(false)
  extensionGrantedMinutes Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  proofs  Proof[]

  @@index([missionId])
}

// ---------------------------------------------------------------------------
// SecondaryTask — checkbox complete only, no proof
// ---------------------------------------------------------------------------
model SecondaryTask {
  id        String   @id @default(cuid())
  missionId String
  objective String
  status    String   @default("pending") // pending, complete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

// ---------------------------------------------------------------------------
// Proof — evidence submitted for a primary task
// ---------------------------------------------------------------------------
model Proof {
  id            String   @id @default(cuid())
  primaryTaskId String
  type          String
  content       String   // text body or URL
  verdict       String?
  reason        String?  // AI reasoning for the verdict
  createdAt     DateTime @default(now())

  primaryTask PrimaryTask @relation(fields: [primaryTaskId], references: [id], onDelete: Cascade)

  @@index([primaryTaskId])
}

// ---------------------------------------------------------------------------
// Streak — daily execution streak per user
// ---------------------------------------------------------------------------
model Streak {
  id             String    @id @default(cuid())
  userId         String    @unique
  current        Int       @default(0)
  longest        Int       @default(0)
  lastActiveDate    DateTime?
  totalFocusMinutes Int       @default(0)
  calendarDays      String?   // JSON array of { date, status }
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// NotificationLog — history of sent Pushover messages
// ---------------------------------------------------------------------------
model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  message   String
  title     String?
  priority  Int?
  status    String   // e.g. "sent", "failed"
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// PushSchedule — queued escalation notifications
// ---------------------------------------------------------------------------
model PushSchedule {
  id            String   @id @default(cuid())
  userId        String
  missionId     String
  step          String   // "deadline", "30min", "60min", "final"
  scheduledTime DateTime
  status        String   // "pending", "sent", "cancelled"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([missionId])
  @@index([status, scheduledTime])
}

// ---------------------------------------------------------------------------
// AppSettings — singleton global configuration managed by admin
// ---------------------------------------------------------------------------
model AppSettings {
  id                   String   @id @default("singleton")
  missionDeadlineHour  Int      @default(22)  // 0-23, hour of day for daily deadline
  maxPrimaryTasks      Int      @default(3)
  maxSecondaryTasks    Int      @default(4)
  pushoverAppToken     String?  // overrides PUSHOVER_APP_TOKEN env var if set
  roadmapSystemPrompt  String?  // overrides hardcoded ROADMAP_SYSTEM if set
  missionSystemPrompt  String?  // overrides hardcoded MISSION_SYSTEM if set
  proofSystemPrompt    String?  // overrides hardcoded PROOF_SYSTEM if set
  decisionSystemPrompt String?  // overrides hardcoded DECISION_FILTER_SYSTEM if set
  updatedAt            DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Vow — Step 0 commitment
// ---------------------------------------------------------------------------
model Vow {
  id               String   @id @default(cuid())
  goalId           String   @unique
  missionStatement String
  whyItMatters     String
  committedAt      DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Reflection — Daily Reflection
// ---------------------------------------------------------------------------
model Reflection {
  id                String   @id @default(cuid())
  missionId         String   @unique
  whatGotDone       String
  whatSlowedYouDown String
  whatYouLearned    String
  focusScore        Int

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// WeeklyReview — Weekly progress report
// ---------------------------------------------------------------------------
model WeeklyReview {
  id                   String   @id @default(cuid())
  goalId               String
  weekNumber           Int
  executionRate        Float
  focusHours           Float
  missionCompletionPct Float
  revenue              Float
  momentumScore        Int
  bottleneck           String
  recommendation       String
  incomeProgress       Float
  leadsFollowedUpPct   Float
  createdAt            DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// ---------------------------------------------------------------------------
// RoleModel — Coaching mentors
// ---------------------------------------------------------------------------
model RoleModel {
  id               String   @id @default(cuid())
  userId           String
  name             String
  principleToLearn String
  notes            String?
  imageUrl         String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Lead — Income goal tracking
// ---------------------------------------------------------------------------
model Lead {
  id               String    @id @default(cuid())
  userId           String
  name             String
  source           String?
  status           String    @default("new") // new, contacted, followed_up, converted, lost
  nextFollowUpDate DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// RevenueLog — Logs daily/weekly revenue progress
// ---------------------------------------------------------------------------
model RevenueLog {
  id          String   @id @default(cuid())
  userId         String
  amount         Float
  description    String
  source         String?
  currency       String   @default("NGN")
  originalAmount Float?
  date           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
